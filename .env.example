# Django
SECRET_KEY=your-super-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — use SQLite for local dev without PostgreSQL
USE_SQLITE=True

# Database (PostgreSQL) — when USE_SQLITE=False
DB_NAME=break_the_silence
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS — origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT token lifetimes (minutes)
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_MINUTES=1440

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: founder image URL (e.g. from Django media or Unsplash)
# NEXT_PUBLIC_FOUNDER_IMAGE=http://localhost:8000/media/founder.jpg
